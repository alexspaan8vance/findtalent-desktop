# ============================================================================
# findtalent — single-tenant whitelabel deploy.
# Copy to .env and fill in. Don't commit the real .env.
# ============================================================================

# --- Database ----------------------------------------------------------------
# SQLite (default, simplest). For prod scale use Postgres.
DATABASE_URL="file:./dev.db"
# Production Docker example: DATABASE_URL="file:/data/findtalent.db"
# Postgres example:         DATABASE_URL="postgresql://user:pw@host:5432/findtalent"

# --- Crypto ------------------------------------------------------------------
# AES-256-GCM key + Auth.js JWT secret. Base64-encoded 32 random bytes each.
# Generate both with:
#   node -e "console.log('ENCRYPTION_KEY=\"' + require('crypto').randomBytes(32).toString('base64') + '\"\nAUTH_SECRET=\"' + require('crypto').randomBytes(32).toString('base64') + '\"')"
ENCRYPTION_KEY=""
AUTH_SECRET=""

# --- App URL -----------------------------------------------------------------
# The public origin your users hit. Used for Stripe redirects + email links.
NEXTAUTH_URL="http://localhost:3000"

# --- Reverse-proxy / client-IP trust -----------------------------------------
# The app runs behind a Tailscale Funnel (+ optional local reverse proxy) that
# appends the REAL client IP as the RIGHTMOST X-Forwarded-For hop; everything to
# the LEFT is client-supplied and untrusted. The client-IP resolver therefore
# reads XFF from the RIGHT. TRUSTED_PROXY_HOP_COUNT is how many trusted proxy
# hops sit to the right of the real client IP (i.e. the real client is the Nth
# token from the right). Default 1 = rightmost entry, which matches the current
# single-proxy Funnel deploy. Raise ONLY if you add another trusted proxy that
# also appends to X-Forwarded-For. (Getting this wrong lets an attacker forge
# the rate-limit/throttle IP — leave at 1 unless you know your proxy chain.)
TRUSTED_PROXY_HOP_COUNT="1"

# --- CSRF Origin allowlist ---------------------------------------------------
# State-changing cookie-auth /api routes reject a cross-site Origin/Referer.
# Set APP_ORIGIN to the PUBLIC origin browsers use (scheme+host+port, no path),
# e.g. "https://findtalent.example.ts.net". Behind the Funnel the internal
# request host differs from the browser origin, so this env value is the
# authoritative allowlist entry. Falls back to NEXTAUTH_URL's origin when unset.
APP_ORIGIN=""

# --- Tenant + 8vance --------------------------------------------------------
# A short slug identifying this deploy + the 8vance company whose pool you
# expose. Used by scripts/bootstrap-admin.ts to create the first Tenant row.
TENANT_SLUG="default"
EIGHTVANCE_CLIENT_ID=""
EIGHTVANCE_CLIENT_SECRET=""
EIGHTVANCE_COMPANY_ID=""
# Default taxonomy locale for 8vance reference-data reads (skill / function /
# education names). 8vance stores names per locale and the talent sub-resource
# reads return the talent's stored locale (often German); we resolve taxonomy
# ids -> names via /resources/*/ which honours ?lang. Defaults to "en" so names
# show in English. Accepted: en|nl|de|fr|it.
EIGHTVANCE_LANG="en"

# --- Stripe -----------------------------------------------------------------
# Test keys work for dev; switch to live keys before launch.
# Stripe webhook URL to register: <NEXTAUTH_URL>/api/webhooks/stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Email (Resend) ---------------------------------------------------------
# Without these, signup verification emails won't send. NB: in PRODUCTION
# signup requires working email (no auto-verify fallback there) — an
# unconfigured mailer makes /signup fail with a config error.
RESEND_API_KEY=""
MAIL_FROM="noreply@findtalent.local"

# --- Signup gating ------------------------------------------------------------
# Comma-separated email domains allowed to self-register, e.g. "8vance.com" or
# "8vance.com,example.org". UNSET/empty in production = signup DISABLED
# (fail-closed — the app fronts a public Tailscale Funnel URL). Unset in
# development = open signup (local dev convenience).
SIGNUP_ALLOWED_DOMAINS="8vance.com"

# --- Scheduled crons ----------------------------------------------------------
# Shared bearer token guarding /api/cron/* (host cron / systemd timer hits them
# over HTTP). Unset = cron routes refuse with 503 (never open by default).
CRON_SECRET=""

# --- Feature flags ------------------------------------------------------------
# Human-in-the-loop CV-suggestions review panel on the candidate match screen.
# Default OFF; only CV_SUGGESTIONS="true" renders the panel.
CV_SUGGESTIONS=""

# --- Travel time (car/bike + optional OV) -----------------------------------
# Car + bike travel-time buckets use OpenRouteService. Without a key the app
# falls back to a Haversine distance estimate (still works, just coarser).
ORS_API_KEY=""
#
# OV (public transport) travel time is OFF by default — the OV filter chip stays
# hidden until ONE of the two sources below is configured. Pick exactly one:
#
#   GOOGLE_MAPS_API_KEY — Google Routes API (computeRouteMatrix, TRANSIT mode).
#                         PAID, billed per origin×destination element. Preferred
#                         when set. See https://developers.google.com/maps/billing
GOOGLE_MAPS_API_KEY=""
#
#   OTP_GRAPHQL_URL     — self-hosted OpenTripPlanner 2 GraphQL endpoint (FREE,
#                         you run the server against a GTFS + OSM feed). One
#                         request per destination. The adapter auto-detects the
#                         modern `planConnection` vs legacy `plan` GraphQL dialect.
#                         In Docker on the same network: http://otp:8080/otp/gtfs/v1
OTP_GRAPHQL_URL=""
#   OTP_DEPART_AT       — optional ISO instant for the OTP depart time; defaults
#                         to the next upcoming weekday 09:00.
OTP_DEPART_AT=""

# --- Branding / whitelabel --------------------------------------------------
BRAND_NAME="FindTalent"
BRAND_PRIMARY_COLOR="#0f172a"
BRAND_SUPPORT_EMAIL=""
BRAND_LOGO_URL=""
BRAND_FAVICON_URL=""

# --- v2match cluster-DNA service (optional; NOT matching) -------------------
# Candidate↔job MATCHING is handled by the 8vance API — findtalent does not run
# its own DNA matcher. This URL only powers the auxiliary /api/normalize and
# /api/reskill helpers (title→canonical function, career-path suggestions) via
# the v2match service (allesio-dashboard/tools/themis/v2match_service.py).
# Unset = those helpers return empty (no-op).
V2MATCH_URL=""            # e.g. http://127.0.0.1:8802
V2MATCH_TIMEOUT_MS="4000" # fail-closed timeout per call

# --- In-app feedback (optional) -------------------------------------------
# Where the in-app Feedback button forwards submissions (n8n webhook -> Jira).
# Empty = feedback is only stored locally + shown in Admin -> Feedback.
FEEDBACK_WEBHOOK_URL=""
FEEDBACK_TIMEOUT_MS="8000"
