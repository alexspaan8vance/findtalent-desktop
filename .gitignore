# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# prisma local sqlite
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-*
tests/*.db
tests/*.db-*
tests/.dbs/

# screenshots
/screenshots/
/e2e-screenshots/
/e2e-report/
/test-results/
prisma/e2e.db
prisma/e2e.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts
scripts/probe-*.ts

# visual walkthrough output
visual-shots/

# qa agent scratch
qa-shots/
qa-*.mjs

qa2-shots/
qa*.mjs
qa*.json

qa*-shots/

qa[0-9]*

e2e-run.log
*.log

# Ad-hoc local debug/probe scripts (decrypt secrets + hit prod) — never commit
_*.cjs

# Playwright MCP session artifacts (test uploads / traces) — never commit
.playwright-mcp/

# Python bytecode (stray local dirs, e.g. under services/ — the v2match
# service itself lives on the chore/v2match-parked branch, not main)
__pycache__/

# electron-builder output
/dist-desktop
