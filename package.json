{
  "name": "findtalent",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev --port 3200",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "stripe:seed": "tsx scripts/stripe-seed.ts",
    "dev:seed-plans": "tsx scripts/dev-seed-plans.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report e2e-report",
    "desktop:dev": "electron desktop/main.js",
    "desktop:template-db": "node scripts/build-template-db.js",
    "desktop:build": "next build && node scripts/build-template-db.js && electron-builder --config desktop/electron-builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "@types/leaflet": "^1.9.21",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.8.9",
    "leaflet": "^1.9.4",
    "mammoth": "^1.12.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "openai": "^6.43.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "word-extractor": "^1.0.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
